---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Hero from '../components/Hero.astro';
import MapEmbed from '../components/MapEmbed.astro';
import HoursTable from '../components/HoursTable.astro';
import OpenStatusPill from '../components/OpenStatusPill.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';
import { buildBreadcrumbSchema } from '../lib/schema';

const siteUrl = (Astro.site?.toString() ?? 'https://www.cozycafeedinburgh.co.uk/').replace(/\/$/, '');
const directionsHref = `https://www.google.com/maps/dir/?api=1&destination=${site.contact.geo.lat},${site.contact.geo.lng}`;
const schema = [buildBreadcrumbSchema(siteUrl, [{ name: 'Home', path: '/' }, { name: 'Visit', path: '/visit' }])];
---

<Layout
  title={`Visit Us${site.seo.titleSuffix}`}
  description="Find Cozy Cafe on Ferry Road, Leith, Edinburgh. Opening hours, directions, parking notes and contact details for Edinburgh's best breakfast takeaway."
  path="/visit"
  schema={schema}
>
  <Hero title="Visit Cozy Cafe" subtitle="36 Ferry Rd, Edinburgh EH6 4AE — right in the heart of Leith." compact />

  <Section>
    <div class="grid gap-10 lg:grid-cols-2">
      <div class="reveal">
        <MapEmbed height="420" />
      </div>

      <div class="reveal flex flex-col gap-8">
        <div>
          <h2 class="font-display text-h3 font-semibold text-espresso">Find us</h2>
          <address class="mt-3 not-italic leading-relaxed text-ink-muted">{site.contact.addressFull}</address>
          <div class="mt-4 flex flex-wrap gap-3">
            <a
              href={site.contact.phoneHref}
              class="inline-flex items-center justify-center gap-2 rounded-pill bg-clay px-5 py-3 font-semibold text-cream shadow-warm-sm transition-all hover:-translate-y-0.5 hover:bg-clay-ink hover:shadow-warm-md active:translate-y-0"
            >
              <Icon name="phone" class="size-4" />
              {site.contact.phoneDisplay}
            </a>
            <a
              href={directionsHref}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 rounded-pill border border-espresso/15 px-5 py-3 font-semibold text-espresso transition-colors hover:bg-oat"
            >
              <Icon name="directions" class="size-4" />
              Get directions
            </a>
          </div>
        </div>

        <div>
          <div class="mb-3 flex items-center gap-3">
            <h2 class="font-display text-h3 font-semibold text-espresso">Opening hours</h2>
            <OpenStatusPill />
          </div>
          <HoursTable />
        </div>

        <div>
          <h2 class="font-display text-h3 font-semibold text-espresso">Parking & getting here</h2>
          <p class="mt-3 text-ink-muted">
            We're on Ferry Road in Leith, a short walk from Great Junction Street and Leith Walk. On-street pay-and-display parking is available
            nearby, and the area is well served by Lothian Buses along Ferry Road — check current routes before you travel. Cycle racks are
            available on neighbouring streets.
          </p>
        </div>

        <div>
          <h2 class="font-display text-h3 font-semibold text-espresso">Follow us</h2>
          <div class="mt-3 flex gap-3">
            <a
              href={site.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex size-11 items-center justify-center rounded-full bg-oat text-espresso transition-colors hover:bg-clay hover:text-cream"
              aria-label="Cozy Cafe on Instagram"
            >
              <Icon name="instagram" class="size-5" />
            </a>
            <a
              href={site.social.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex size-11 items-center justify-center rounded-full bg-oat text-espresso transition-colors hover:bg-clay hover:text-cream"
              aria-label="Cozy Cafe on Facebook"
            >
              <Icon name="facebook" class="size-5" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </Section>
</Layout>
