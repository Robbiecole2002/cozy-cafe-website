---
---

<div
  id="cookie-consent"
  hidden
  role="region"
  aria-label="Cookie consent"
  class="fixed inset-x-0 bottom-16 z-40 mx-auto flex max-w-xl flex-col gap-3 rounded-card-lg border border-oat bg-white p-5 shadow-warm-lg sm:bottom-6 sm:left-6 sm:right-auto sm:mx-0 lg:bottom-6"
>
  <p class="text-sm text-espresso">
    We use a small amount of cookies to understand how visitors use this site. No marketing trackers, no data sold. You can accept or decline —
    the site works either way.
  </p>
  <div class="flex flex-wrap gap-3">
    <button
      id="cookie-accept"
      type="button"
      class="inline-flex items-center justify-center rounded-pill bg-clay px-5 py-2.5 text-sm font-semibold text-cream transition-all hover:-translate-y-0.5 hover:bg-clay-ink active:translate-y-0"
    >
      Accept
    </button>
    <button
      id="cookie-reject"
      type="button"
      class="inline-flex items-center justify-center rounded-pill border border-espresso/20 px-5 py-2.5 text-sm font-semibold text-espresso transition-colors hover:bg-oat"
    >
      Decline
    </button>
  </div>
</div>

<script src="../scripts/cookie-consent.ts"></script>
