---
import { site, type Offer } from '../data/site';

interface Props {
  offer: Offer;
}

const { offer } = Astro.props;
---

<article class="reveal flex flex-col gap-4 rounded-card-lg border border-honey/30 bg-white p-6 shadow-warm-sm transition-shadow duration-300 hover:shadow-warm-md sm:p-7">
  <div class="flex items-start justify-between gap-4">
    <h3 class="font-display text-xl font-medium text-espresso">{offer.title}</h3>
    {offer.badge && (
      <span class="whitespace-nowrap rounded-pill bg-honey/25 px-3 py-1 font-display text-lg font-semibold text-espresso">{offer.badge}</span>
    )}
  </div>
  <p class="text-ink-muted">{offer.description}</p>
  <p class="text-xs text-ink-muted">{offer.terms}</p>
  <a
    href={site.links.order}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-auto inline-flex w-fit items-center justify-center rounded-pill bg-clay px-5 py-2.5 text-sm font-semibold text-cream shadow-warm-sm transition-all duration-200 hover:-translate-y-0.5 hover:bg-clay-ink hover:shadow-warm-md active:translate-y-0"
  >
    Order this deal
  </a>
</article>
