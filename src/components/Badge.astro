---
import Icon from './Icon.astro';
import type { MenuBadge } from '../data/menu';

interface Props {
  type: MenuBadge;
}

const { type } = Astro.props;

const config: Record<MenuBadge, { label: string; icon: 'flame' | 'leaf' | 'star' | 'bag'; classes: string }> = {
  Popular: { label: 'Popular', icon: 'star', classes: 'bg-honey/20 text-espresso' },
  Vegetarian: { label: 'Vegetarian', icon: 'leaf', classes: 'bg-sage/15 text-sage-ink' },
  Spicy: { label: 'Spicy', icon: 'flame', classes: 'bg-clay/10 text-clay-ink' },
  Deal: { label: 'Deal', icon: 'bag', classes: 'bg-paprika/15 text-clay-ink' },
};

const { label, icon, classes } = config[type];
---

<span class={`inline-flex items-center gap-1 rounded-pill px-2.5 py-1 text-xs font-semibold tracking-wide ${classes}`}>
  <Icon name={icon} class="size-3" />
  {label}
</span>
