---
import { site } from '../data/site';
import OpenStatusPill from './OpenStatusPill.astro';
import RatingStars from './RatingStars.astro';
import FoodImage from './FoodImage.astro';

interface Props {
  title: string;
  subtitle?: string;
  image?: string;
  compact?: boolean;
  showActions?: boolean;
}

const { title, subtitle, image, compact = false, showActions = false } = Astro.props;
---

<section class={`relative overflow-hidden ${compact ? 'py-16 sm:py-20' : 'py-20 sm:py-28 lg:py-36'}`}>
  <div class="absolute inset-0">
    <FoodImage src={image} alt="" label="Warm hero photo of the café coming soon" aspect="16/9" class="h-full rounded-none" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-t from-espresso via-espresso/55 to-espresso/10"></div>
    <div class="grain-overlay"></div>
  </div>

  <div class="relative mx-auto flex max-w-6xl flex-col items-start gap-5 px-5 sm:px-8">
    {!compact && (
      <RatingStars value={site.rating.value} count={site.rating.count} class="rounded-pill bg-cream/90 px-3 py-1.5" />
    )}

    <h1 class="max-w-3xl text-h1 font-display font-semibold text-cream">{title}</h1>

    {subtitle && <p class="max-w-xl text-lead text-cream/90">{subtitle}</p>}

    {showActions && (
      <div class="flex flex-wrap items-center gap-3 pt-2">
        <a
          href={site.links.order}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-pill bg-clay px-7 py-3.5 font-semibold text-cream shadow-warm-md transition-all hover:-translate-y-0.5 hover:bg-clay-ink active:translate-y-0"
        >
          Order Online
        </a>
        <a
          href="/menu"
          class="inline-flex items-center justify-center rounded-pill border-2 border-cream/70 px-7 py-3.5 font-semibold text-cream transition-all hover:-translate-y-0.5 hover:bg-cream hover:text-espresso active:translate-y-0"
        >
          View Menu
        </a>
      </div>
    )}

    <OpenStatusPill class="mt-2 bg-cream/95" />
  </div>
</section>
