---
import { site } from '../data/site';
import Icon from './Icon.astro';
import HoursTable from './HoursTable.astro';
import OpenStatusPill from './OpenStatusPill.astro';

const directionsHref = `https://www.google.com/maps/dir/?api=1&destination=${site.contact.geo.lat},${site.contact.geo.lng}`;
---

<footer class="bg-espresso pb-24 pt-16 text-cream/90 lg:pb-16">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 sm:px-8 md:grid-cols-4">
    <div class="md:col-span-1">
      <p class="font-display text-2xl font-semibold text-cream">Cozy<span class="text-honey">Cafe</span></p>
      <p class="mt-3 text-sm text-cream/70">{site.shortDescription}</p>
      <div class="mt-4 flex gap-3">
        <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" class="inline-flex size-10 items-center justify-center rounded-full bg-cream/10 transition-colors hover:bg-cream/20" aria-label="Cozy Cafe on Instagram">
          <Icon name="instagram" class="size-5" />
        </a>
        <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" class="inline-flex size-10 items-center justify-center rounded-full bg-cream/10 transition-colors hover:bg-cream/20" aria-label="Cozy Cafe on Facebook">
          <Icon name="facebook" class="size-5" />
        </a>
        <a href={site.links.androidApp} target="_blank" rel="noopener noreferrer" class="inline-flex size-10 items-center justify-center rounded-full bg-cream/10 transition-colors hover:bg-cream/20" aria-label="Cozy Cafe app on Google Play">
          <Icon name="android" class="size-5" />
        </a>
      </div>
    </div>

    <div>
      <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-honey">Hours</h2>
      <div class="mt-3">
        <OpenStatusPill class="mb-3" />
        <HoursTable
          compact
          class="text-cream/80 [&_.text-espresso]:text-cream [&_.text-ink-muted]:text-cream/75 [&_tr]:border-cream/10 [&_th]:text-cream/90 [&_.font-semibold]:text-cream"
        />
      </div>
    </div>

    <div>
      <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-honey">Visit</h2>
      <address class="mt-3 not-italic text-sm leading-relaxed text-cream/80">{site.contact.addressFull}</address>
      <a href={site.contact.phoneHref} class="mt-2 inline-flex items-center gap-2 text-sm font-semibold text-cream hover:text-honey">
        <Icon name="phone" class="size-4" />
        {site.contact.phoneDisplay}
      </a>
      <a href={directionsHref} target="_blank" rel="noopener noreferrer" class="mt-2 flex items-center gap-2 text-sm font-semibold text-cream hover:text-honey">
        <Icon name="directions" class="size-4" />
        Get directions
      </a>
    </div>

    <div>
      <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-honey">Cozy Cafe</h2>
      <ul class="mt-3 flex flex-col gap-2 text-sm text-cream/80">
        {site.nav.map((link) => (
          <li><a href={link.href} class="hover:text-honey">{link.label}</a></li>
        ))}
        {site.footerLegalLinks.map((link) => (
          <li><a href={link.href} class="hover:text-honey">{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="mx-auto mt-12 max-w-6xl px-5 text-xs text-cream/70 sm:px-8">
    <p>{site.surchargeNote}</p>
    <p class="mt-2">&copy; {new Date().getFullYear()} {site.legalName}. {site.contact.addressFull}.</p>
  </div>
</footer>
