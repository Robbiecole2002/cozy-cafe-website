---
import Badge from './Badge.astro';
import type { MenuCategory } from '../data/menu';

interface Props {
  category: MenuCategory;
}

const { category } = Astro.props;
---

<section id={category.id} class="reveal scroll-mt-32 border-b border-oat py-10 first:pt-0 last:border-0">
  <div class="mb-6">
    <h2 class="font-display text-2xl font-medium text-espresso sm:text-h3">{category.title}</h2>
    {category.note && <p class="mt-1 text-sm italic text-ink-muted">{category.note}</p>}
  </div>

  <ul class="grid gap-x-8 gap-y-6 sm:grid-cols-2">
    {
      category.items.map((item) => (
        <li class="flex flex-col gap-1 border-b border-oat/70 pb-4 sm:border-0 sm:pb-0">
          <div class="flex items-baseline justify-between gap-3">
            <span class="font-display text-base font-medium text-espresso">{item.name}</span>
            {item.price && <span class="whitespace-nowrap font-semibold text-clay-ink">{item.price}</span>}
          </div>
          {item.description && <p class="text-sm text-ink-muted">{item.description}</p>}
          {item.prices && (
            <ul class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-ink-muted">
              {item.prices.map((p) => (
                <li>
                  {p.label}: <span class="font-semibold text-clay-ink">{p.price}</span>
                </li>
              ))}
            </ul>
          )}
          {item.badges && item.badges.length > 0 && (
            <div class="mt-1 flex flex-wrap gap-1.5">
              {item.badges.map((b) => (
                <Badge type={b} />
              ))}
            </div>
          )}
        </li>
      ))
    }
  </ul>
</section>
