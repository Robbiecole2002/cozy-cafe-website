---
import { site } from '../data/site';
import OpenStatusPill from './OpenStatusPill.astro';
import MobileNav from './MobileNav.astro';

const currentPath = Astro.url.pathname;

const isActive = (href: string) => (href === '/' ? currentPath === '/' : currentPath.startsWith(href));
---

<header class="sticky top-0 z-30 border-b border-oat/70 bg-cream/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-3 sm:px-8">
    <a href="/" class="flex items-center gap-2 font-display text-2xl font-semibold tracking-tight text-espresso">
      Cozy<span class="text-clay">Cafe</span>
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-1 lg:flex">
      {
        site.nav.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
            class={`rounded-pill px-4 py-2 text-sm font-semibold transition-colors ${
              isActive(link.href) ? 'bg-oat text-espresso' : 'text-ink-muted hover:bg-oat/60 hover:text-espresso'
            }`}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <OpenStatusPill class="hidden sm:inline-flex" />
      <a
        href={site.links.order}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden items-center justify-center rounded-pill bg-clay px-5 py-2.5 text-sm font-semibold text-cream shadow-warm-sm transition-all hover:-translate-y-0.5 hover:bg-clay-ink hover:shadow-warm-md active:translate-y-0 sm:inline-flex"
      >
        Order Online
      </a>
      <MobileNav />
    </div>
  </div>
</header>
