---
import Icon from './Icon.astro';

interface Props {
  value: number;
  count?: number;
  class?: string;
  showCount?: boolean;
}

const { value, count, class: className = '', showCount = true } = Astro.props;
const fullStars = Math.floor(value);
const hasHalf = value - fullStars >= 0.5;
const stars = Array.from({ length: 5 }, (_, i) => {
  if (i < fullStars) return 'star';
  if (i === fullStars && hasHalf) return 'star-half';
  return 'empty';
});
---

<span class={`inline-flex items-center gap-2 ${className}`} role="img" aria-label={`Rated ${value} out of 5 stars${count ? ` from ${count} reviews` : ''}`}>
  <span class="inline-flex text-honey" aria-hidden="true">
    {stars.map((s) => (s === 'empty' ? <Icon name="star" class="size-4 text-oat" /> : <Icon name={s} class="size-4" />))}
  </span>
  <span class="text-sm font-semibold text-espresso">{value.toFixed(1)}</span>
  {showCount && count && <span class="text-sm text-ink-muted">· {count} reviews</span>}
</span>
